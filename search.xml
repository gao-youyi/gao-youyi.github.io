    <content><![CDATA[<pre><code>&#39;&#39;&#39;
#include&lt;stdio.h&gt;
#include&lt;string.h&gt;
#include&lt;stdlib.h&gt;
//线索二叉树
/*
目的：更加充分的利用结点的空间
操作：让所有的空的指针域都指向前驱结点和后继的节点
</code></pre>
<span id="more"></span>
<pre><code>方法：为了区别于没有子树的指针和指向子树的指针，我们设置两个标志位
*/
enum PointerTag &#123;Link,Thread//Link是指针，指向子树，Thread是线索 
&#125;; //定义一种新的数据类型，用来判断是那种指针域 
struct BiThrNode&#123;
char data;
BiThrNode *lchild,*rchild;
PointerTag LTag,RTag;//

&#125;;
typedef BiThrNode *BiThrTree;

// 创建线索二叉树
//这里采用的是中序遍历 
/*
这里需要创建一个 头节点，指向树根
还要设置一对结
*/
BiThrNode *pre;
void Thread(BiThrNode *&amp;p)&#123;
if(p!= NULL)&#123;
    Thread(p-&gt;lchild);//左子树线索化 
    if(p-&gt;lchild ==NULL)&#123;//前驱线索 
        p-&gt;lchild = pre;//给结点P添加前驱线索 
        p-&gt;LTag = 1;
    &#125;
    else
        p-&gt;LTag = 0;
    if(pre-&gt;rchild==NULL)&#123;
        pre-&gt;rchild = p;//给结点pre提娜佳后继线索 
        pre-&gt;RTag = 1;
    &#125;
    else
        pre-&gt;RTag = 0;
    pre = p;
    Thread(p-&gt;rchild); //右子树线索化 
&#125;
&#125; 

//对以bt为根结点的二叉树中序线索化，并增加一个头结点head 
BiThrNode *CreaThread(BiThrNode *bt)&#123;
BiThrNode *head;
head = (BiThrNode *)malloc (sizeof(BiThrNode));
head-&gt;LTag = 0;
head-&gt;RTag = 1;//创建头结点head 
head-&gt;rchild= bt;
if(bt==NULL)//如果头结点为空，只是头结点自身为树 
    head-&gt;lchild = head;
else&#123;
    head-&gt;lchild = bt;
    pre = head;//pre是p的前驱结点，供加线索使用 
    Thread(bt);//中序遍历线索化二叉树 
    pre-&gt;rchild = head;//最后处理，加入指向根结点的线索 
    pre-&gt;RTag = 1;
    head-&gt;rchild = pre;//根结点右线索化 
    
&#125;
return head;
&#125; 
&#39;&#39;&#39;
</code></pre>
]]></content>
